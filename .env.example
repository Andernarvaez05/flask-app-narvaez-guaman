# Este archivo es una plantilla. El .env real con los valores verdaderos
# NUNCA se sube a Git — se crea una sola vez, a mano, en el VPS
# (~/proyecto-devops/app/.env) y GitHub Actions nunca lo toca ni lo sobreescribe.

# --- Backend (conexión a la Postgres ya existente en el VPS) ---
POSTGRES_USER=admin_guaman_narvaez
POSTGRES_PASSWORD=12345
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=app_usuarios
SECRET_KEY=changeme-backend

# --- Frontend ---
BACKEND_URL=http://backend:5000
ADMIN_USERNAME=admin
# Generar con:
# python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('tu_password_aqui'))"
#
# IMPORTANTE: Docker Compose interpola variables ($VAR) tanto en docker-compose.yml
# como en los valores leídos de este .env cuando se pasan via env_file. El hash de
# scrypt/pbkdf2 contiene signos $ (ej. scrypt:32768:8:1$salt$hash), así que hay que
# escapar CADA $ como $$ aquí, o Compose intentará sustituirlo como variable y lo
# dejará en blanco silenciosamente (verás un WARN "variable is not set").
# Ejemplo correcto:
# ADMIN_PASSWORD_HASH=scrypt:32768:8:1$$SALT_AQUI$$HASH_AQUI
ADMIN_PASSWORD_HASH=changeme-hash
